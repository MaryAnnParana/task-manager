{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/css/.*",
      "dest": "/dist/css/$1"
    },
    {
      "src": "/js/.*",
      "dest": "/dist/js/$1"
    },
    {
      "src": "/(.+\\..+)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)$",
      "dest": "/api/index.php"
    }
  ],
  "buildCommand": "npm run build",
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_KEY": "base64:pNJsNbVwdUR7gU4hZM3s0ijxBBk814cAGpJEzpQPatQ=",
    "DB_CONNECTION": "sqlite",
    "DB_DATABASE": "/tmp/database.sqlite",
    "CACHE_STORE": "file",
    "QUEUE_CONNECTION": "sync"
  }
}