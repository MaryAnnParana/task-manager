{
  "version": 2,
  "buildCommand": "npm run build && php artisan optimize",
  "outputDirectory": "public",
  "framework": "laravel",
  "php": {
    "version": "8.3"
  },
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false"
  },
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}